{
  "name": "chat-interface",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web:wait\"",
    "dev:api": "python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000 --app-dir backend --reload-dir backend --no-access-log",
    "dev:web": "npm run dev --prefix frontend",
    "dev:web:wait": "wait-on tcp:127.0.0.1:8000 && npm run dev:web",
    "test:backend": "python testing/scripts/run_backend_tests.py"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "wait-on": "^9.0.4"
  }
}